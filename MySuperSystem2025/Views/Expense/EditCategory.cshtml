@model MySuperSystem2025.Models.ViewModels.Expense.EditExpenseCategoryViewModel
@{
    ViewData["Title"] = "Edit Expense Category";
}

<link rel="stylesheet" href="~/css/unified-forms.css" />

<div class="form-container">
    <div class="page-header">
        <h1><i class="bi bi-pencil me-2"></i>Edit Expense Category</h1>
        <p class="text-muted mb-0">Update category details and budget</p>
    </div>

    <div class="form-card">
        @if (Model.IsDefault)
        {
            <div class="info-box">
                <i class="bi bi-info-circle"></i>
                <small>This is a <strong>default category</strong>. You can modify its settings.</small>
            </div>
        }

        <form asp-action="EditCategory" method="post">
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="mb-3">
                <label asp-for="Name" class="form-label">Category Name</label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label">Description (Optional)</label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="BudgetAmount" class="form-label">Budget Amount (&#8369;)</label>
                <input asp-for="BudgetAmount" class="form-control" type="number" step="0.01" min="0" />
                <span asp-validation-for="BudgetAmount" class="text-danger"></span>
                <small class="text-muted d-block mt-1">Current remaining: &#8369;@Model.RemainingAmount.ToString("N2")</small>
            </div>

            <div class="mb-3">
                <label asp-for="MonthlyFixedBudget" class="form-label">Monthly Fixed Budget (&#8369;)</label>
                <input asp-for="MonthlyFixedBudget" class="form-control" type="number" step="0.01" min="0" />
                <span asp-validation-for="MonthlyFixedBudget" class="text-danger"></span>
                <small class="text-muted d-block mt-1">Budget resets automatically every month</small>
            </div>

            @if (Model.MonthlyFixedBudget > 0)
            {
                <div class="mb-3">
                    <div class="form-check form-switch">
                        <input asp-for="IsBudgetActive" class="form-check-input" type="checkbox" role="switch" id="budgetActiveSwitch" />
                        <label class="form-check-label" for="budgetActiveSwitch">
                            <span class="fw-bold">Monthly Budget Active</span>
                        </label>
                    </div>
                    <small class="text-muted d-block mt-1">
                        @if (Model.IsBudgetActive)
                        {
                            <span class="text-success"><i class="bi bi-check-circle me-1"></i>Active — budget resets every month and counts toward totals</span>
                        }
                        else
                        {
                            <span class="text-warning"><i class="bi bi-pause-circle me-1"></i>Paused — budget will NOT reset and is excluded from monthly totals</span>
                        }
                    </small>
                </div>

                <div class="mb-3">
                    <div class="form-check form-switch">
                        <input asp-for="RolloverEnabled" class="form-check-input" type="checkbox" role="switch" id="rolloverSwitch" />
                        <label class="form-check-label" for="rolloverSwitch">
                            <span class="fw-bold">Rollover Unspent Budget</span>
                        </label>
                    </div>
                    <small class="text-muted d-block mt-1">
                        @if (Model.RolloverEnabled)
                        {
                            <span class="text-success"><i class="bi bi-arrow-repeat me-1"></i>Enabled — leftover from last month is added to next month's budget</span>
                        }
                        else
                        {
                            <span class="text-muted"><i class="bi bi-x-circle me-1"></i>Disabled — each month starts fresh with the fixed budget only</span>
                        }
                    </small>
                </div>
            }

            @if (Model.TotalExpenses > 0)
            {
                <div class="warning-box">
                    <i class="bi bi-exclamation-triangle"></i>
                    <small>This category has <strong>&#8369;@Model.TotalExpenses.ToString("N2")</strong> in expenses. Changing the budget will recalculate the remaining balance.</small>
                </div>
            }

            <div class="form-actions">
                <button type="submit" class="btn btn-primary">
                    <i class="bi bi-check-circle me-1"></i>Update Category
                </button>
                <a asp-action="Categories" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

